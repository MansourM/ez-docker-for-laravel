# ============================================
# EZ Docker For Laravel - Security Configuration
# ============================================
# This file contains security-related configuration with pinned versions.
# Copy this file to .env and customize as needed for your environment.
# The .env file is gitignored to keep local configurations private.

# ============================================
# Docker Image Versions (Security: Pin to specific versions)
# ============================================
# These versions have been tested and verified for security and stability.
# Update these versions after testing in dev/staging environments.
# Last updated: 2024-01-12

# Nginx Proxy Manager - Reverse proxy with Let's Encrypt support
NGINX_PM_VERSION=2.11.1

# MySQL - Database server
MYSQL_VERSION=8.0.35

# phpMyAdmin - Database management interface
PHPMYADMIN_VERSION=5.2.1

# Portainer - Container management UI
PORTAINER_VERSION=2.19.4

# ============================================
# Database Security Settings
# ============================================
# Network restriction for MySQL users (Docker network only)
# Default: 172.%.%.% restricts access to Docker internal network
DB_NETWORK_RESTRICTION=172.%.%.%

# ============================================
# Input Validation Settings
# ============================================
# Password length constraints
MAX_PASSWORD_LENGTH=128
MIN_PASSWORD_LENGTH=8

# Application name constraints
MAX_APP_NAME_LENGTH=64

# Allowed environment names (comma-separated)
ALLOWED_ENVIRONMENTS=dev,test,staging,production

# ============================================
# Security Headers Configuration
# ============================================
# Enable comprehensive security headers
SECURITY_HEADERS_ENABLED=true

# HSTS (HTTP Strict Transport Security) max age in seconds
HSTS_MAX_AGE=31536000

# Content Security Policy (CSP)
# Adjust based on your application's needs
CSP_POLICY="default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self'; frame-ancestors 'self';"

# ============================================
# OPcache Configuration
# ============================================
# Development: 1 (check for file changes)
# Production: 0 (maximum performance)
OPCACHE_VALIDATE_TIMESTAMPS=1

# ============================================
# PHP Configuration
# ============================================
# Display errors (On for dev, Off for production)
PHP_DISPLAY_ERRORS=On

# ============================================
# Version Update Notes
# ============================================
# To update Docker image versions:
# 1. Test new versions in dev environment first
# 2. Update version numbers in this file
# 3. Run: docker compose pull
# 4. Redeploy: ./ez laravel deploy <app> <env>
# 5. Verify all services are working correctly
# 6. Document changes in git commit message
